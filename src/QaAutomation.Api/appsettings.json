{
  "ConnectionStrings": {
    "QaAutomation": "Server=(localdb)\\mssqllocaldb;Database=QaAutomation;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Cors": { "AllowedOrigins": [ "http://localhost:5173" ] },
  "Scanner": {
    "OverallTimeoutSeconds": 120,
    "NavigationTimeoutMilliseconds": 30000,
    "ActionTimeoutMilliseconds": 10000,
    "MaximumDetectedElements": 150,
    "ScreenshotDirectory": "app-data/scans",
    "ElementScreenshotPadding": 8,
    "Headless": true,
    "ViewportWidth": 1440,
    "ViewportHeight": 900,
    "MaximumDiagnosticRecords": 250
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*"
}
